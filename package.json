{
  "name": "myapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "emulate": "npm --prefix ./functions run build && set \"GOOGLE_APPLICATION_CREDENTIALS=credential.json\" && firebase emulators:start --import=./emulator-data --export-on-exit",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "overrides": {
    "typescript": "$typescript"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.28.1",
    "svelte-check": "^4.1.6",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@ai-sdk/cerebras": "^2.0.45",
    "@ai-sdk/google": "^3.0.64",
    "@cerebras/cerebras_cloud_sdk": "^1.35.0",
    "@cloudflare/turnstile-firebase-app-check": "^0.0.5",
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@runware/sdk-js": "^1.1.40",
    "@tailwindcss/postcss": "^4.1.11",
    "@twind/core": "^1.1.3",
    "@twind/preset-autoprefix": "^1.0.7",
    "@twind/with-web-components": "^1.1.3",
    "ai": "^6.0.168",
    "firebase": "^11.9.1",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2",
    "groq-sdk": "^0.23.0",
    "marked": "^15.0.12",
    "openai": "^5.2.0",
    "postcss": "^8.5.6",
    "svelte-turnstile": "^0.11.0",
    "tailwindcss": "^4.1.11",
    "zod": "^3.25.76"
  }
}
