# Firebase Configuration
# Replace these with your actual Firebase project credentials
PUBLIC_FIREBASE_API_KEY=your-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Per-prompt model selection (SvelteKit side)
PAGE_DESIGNER_MODEL=gpt-oss-120b
HTML_GENERATOR_MODEL=gpt-oss-120b
ACTION_RUNNER_MODEL=gpt-oss-120b
IMAGE_DESCRIPTION_MODEL=llama3.1-8b
IMAGE_GENERATION_MODEL=runware:100@1

# Per-prompt model selection (Firebase functions side — also set in functions/.env)
COMPONENT_DESIGNER_MODEL=gpt-oss-120b
COMPONENT_CODEGEN_MODEL=gpt-oss-120b
COMPONENT_EVALUATOR_MODEL=gpt-oss-120b
FEEDBACK_EVALUATOR_MODEL=gpt-oss-120b
COMPONENT_INITIALIZER_MODEL=gpt-oss-120b
COMPONENT_CURATOR_MODEL=gpt-oss-120b
